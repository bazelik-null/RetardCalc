// Introduction to Variables
// To execute use ./Morsel examples/variables.msl
// Or ./Morsel and "file examples/variables.msl"

func main() {
    std::io::println("\n== What is a Variable? ==")
    std::io::println("A variable is a named storage location that holds a value or data.\n")

    // Creating a variable with an explicit type
    let message: string = "Hello, Morsel!";
    std::io::println(message);

    // Creating a variable with an explicit type (number)
    let age: int = 100;
    std::io::println("My age is:", age);


    std::io::println("\n== Automatic Type Detection ==")
    std::io::println("You don't always need to write the type. Morsel figures it out!\n")

    // Morsel automatically detects the type from the value
    let count = 10 + 11;      // This is an int
    let temperature = 24.6;   // This is a float
    let nickname = "Bazelik"; // This is a string
    let isRaining = false;    // This is a bool

    std::io::println("count:", count);
    std::io::println("temperature:", temperature);
    std::io::println("nickname:", nickname);
    std::io::println("isRaining:", isRaining);


    std::io::println("\n== Changing Variables ==")
    std::io::println("By default, variables cannot change. Use 'mut' to allow changes.\n")

    // This variable cannot be changed
    let favorite_color = "blue";
    std::io::println("Favorite color:", favorite_color);
    // favorite_color = "red"; // [ERROR]: Cannot reassign immutable variable: 'x'

    // This variable CAN be changed because of 'mut'
    let mut score = 0;
    std::io::println("Starting score:", score);

    score = 10;
    std::io::println("Updated score:", score);

    score = 25;
    std::io::println("Updated score:", score);


    std::io::println("\n== Simple Math with Variables ==")
    std::io::println("You can do calculations with variables.\n")

    let apples = 5;
    let oranges = 3;
    let total_fruit = apples + oranges;

    std::io::println("Apples:", apples);
    std::io::println("Oranges:", oranges);
    std::io::println("Total fruit:", total_fruit);

    let radius = 4;
    let mut area: float = pi * radius^2; // 'pi' is a builtin constant like. There is also 'e'

    std::io::println("Radius:", radius);
    std::io::println("Area:", area);

    std::io::println("\nBut i need it as int!");
    area = std::math::round(area); // Rounding functions can return any numeric type

    // We can use 'to_type' to cast variables to another type.
    let area_int: int = std::to_int(area);

    std::io::println("Area int:", area_int);
}
