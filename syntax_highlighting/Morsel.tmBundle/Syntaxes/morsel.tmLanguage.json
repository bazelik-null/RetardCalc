{
  "name": "Morsel",
  "scopeName": "source.morsel",
  "fileTypes": [
    "morsel",
    "msl"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#variables"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.morsel",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.morsel",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.morsel",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.morsel",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.morsel",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.morsel",
          "match": "\\b(fn|let|mut|if|else|while|for|return)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.morsel",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.morsel",
          "match": "\\b(int|float|string|bool|null|any)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.morsel",
          "match": "\\b(true|false|pi|e)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.morsel",
          "match": "[+\\-*/%^]"
        },
        {
          "name": "keyword.operator.assignment.morsel",
          "match": "="
        },
        {
          "name": "keyword.operator.comparison.morsel",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.morsel",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "punctuation.separator.morsel",
          "match": "[;,:]"
        },
        {
          "name": "punctuation.bracket.morsel",
          "match": "[{}()\\[\\]]"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.morsel",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
